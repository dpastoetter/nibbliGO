<?xml version="1.0" encoding="utf-8"?>
<!--
  Privacy: nibbliGO keeps chats, companion memory, and pet data local. Exclude everything from
  cloud backup and device-to-device transfer so a child's conversations never leave the phone.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
